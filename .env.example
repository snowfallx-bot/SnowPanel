# Shared
APP_ENV=development
FRONTEND_PORT=5173

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
BACKEND_READ_TIMEOUT=5s
BACKEND_WRITE_TIMEOUT=10s
AGENT_TARGET=127.0.0.1:50051
AGENT_TIMEOUT=3s
JWT_SECRET=change-me-in-production
JWT_ISSUER=snowpanel-backend
JWT_EXPIRE=24h
BOOTSTRAP_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@snowpanel.local
DEFAULT_ADMIN_PASSWORD=admin123456

# Core agent
CORE_AGENT_HOST=0.0.0.0
CORE_AGENT_PORT=50051
CORE_AGENT_ALLOWED_ROOTS=/tmp,/var/tmp,/home
CORE_AGENT_MAX_READ_BYTES=1048576
CORE_AGENT_MAX_WRITE_BYTES=1048576
CORE_AGENT_SERVICE_WHITELIST=nginx.service,sshd.service,docker.service
CORE_AGENT_CRON_ALLOWED_COMMANDS=backup,logrotate,cleanup

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=snowpanel
POSTGRES_USER=snowpanel
POSTGRES_PASSWORD=snowpanel
POSTGRES_SSLMODE=disable
POSTGRES_TIMEZONE=UTC
POSTGRES_MAX_OPEN_CONNS=20
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=30m

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8080
